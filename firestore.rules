rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - papersCompleted: number (required)
    //
    // Collection: user_papers
    // Document ID: {paperId}
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - fileUrl: string (required)
    //   - annotations: string (optional)
    //   - status: string (required, 'in-progress' or 'completed')
    //   - score: number (optional)
    //   - updatedAt: string (required)
    //
    // Collection: friendships
    // Document ID: {friendshipId}
    // Fields:
    //   - user1Id: string (required)
    //   - user2Id: string (required)
    //   - status: string (required, 'pending' or 'accepted')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'papersCompleted']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             data.papersCompleted is number && data.papersCompleted >= 0;
    }

    function isValidUserPaper(data) {
      return hasOnlyAllowedFields(['userId', 'title', 'fileUrl', 'annotations', 'status', 'score', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.fileUrl is string && data.fileUrl.size() > 0 && data.fileUrl.size() < 1000 &&
             (!('annotations' in data) || (data.annotations is string && data.annotations.size() < 1048576)) &&
             data.status in ['in-progress', 'completed'] &&
             (!('score' in data) || (data.score is number && data.score >= 0)) &&
             data.updatedAt is string && data.updatedAt.size() < 50;
    }

    function isValidFriendship(data) {
      return hasOnlyAllowedFields(['user1Id', 'user2Id', 'status']) &&
             data.user1Id is string && data.user1Id.size() > 0 && data.user1Id.size() < 100 &&
             data.user2Id is string && data.user2Id.size() > 0 && data.user2Id.size() < 100 &&
             data.status in ['pending', 'accepted'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /user_papers/{paperId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidUserPaper(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidUserPaper(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendship(request.resource.data) && (request.resource.data.user1Id == request.auth.uid || request.resource.data.user2Id == request.auth.uid);
      allow update: if isAuthenticated() && isValidFriendship(request.resource.data) && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid) && request.resource.data.user1Id == resource.data.user1Id && request.resource.data.user2Id == resource.data.user2Id;
      allow delete: if isAuthenticated() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
    }
  }
}
